---
import Logo from './icons/Logo.astro'
import Menu from './icons/Menu.astro'
import Close from './icons/Close.astro'
import navigation from '../data/navigation.js'
---

<div
  transition:persist
  class="w-full h-0"
  x-data
  x-intersect:enter="$dispatch('top-enter')"
  x-intersect:leave="$dispatch('top-leave')"
></div>

<header
  transition:persist
  class="fixed top-4 left-0 right-0 w-full z-50"
  x-data="{ isTop: window.scrollY === 0, showMobile: false }"
  @top-enter.window="isTop = true"
  @top-leave.window="isTop = false"
>
  <div class="container">
    <div
      x-ref="navigation"
      class="mx-auto rounded-full py-2 flex-wrap flex gap-x-4 gap-y-2 items-center justify-between duration-500 transition-all max-w-full w-full px-0"
      :class="{
        'w-full px-0': isTop,
        'bg-black/50 backdrop-blur w-3xl px-4 transition-all text-white': !isTop || showMobile,
      }"
    >
      <!-- Logo -->
      <div class="flex items-center justify-start flex-none md:w-40">
        <a href="/" class="flex items-center gap-1">
          <Logo class="size-8" />
          <span class="text-lg font-medium">matt<span class="font-extrabold">waler</span></span>
        </a>
      </div>
      <!-- Desktop Links -->
      <div class="justify-center items-center gap-8 hidden md:flex">
        {navigation.map(item => (
          <a class="font-medium opacity-90" href={item.route}>{item.name}</a>
        ))}
      </div>
      <!-- CTA & Menu -->
      <div class="flex-none items-center justify-end flex gap-4 md:w-40">
        <a class="button max-[400px]:hidden" href="/contact/">Get In Touch</a>
        <button
          aria-label="toggle navigation"
          class="flex items-center justify-center md:hidden"
          @click="showMobile = !showMobile"
        >
          <span x-show="!showMobile">
            <Menu class="size-6" />
          </span>
          <span x-show="showMobile" style="display:none">
            <Close class="size-6" />
          </span>
        </button>
      </div>
    </div>
    <!-- Mobile Links -->
    <div
      class="bg-black/50 px-4 mt-1 flex items-center justify-center backdrop-blur rounded-full text-white md:hidden"
      x-anchor.bottom="$refs.navigation"
      x-cloak
      x-transition.duration.300ms
      x-show="showMobile"
    >
      {navigation.map(item => (
        <a x-on:click="showMobile = false" class="font-medium text-lg px-4 py-2" href={item.route}>{item.name}</a>
      ))}
    </div>
  </div>
</header>
