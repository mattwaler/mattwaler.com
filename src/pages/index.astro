---
import { getCollection } from 'astro:content'
import Layout from '../layouts/Layout.astro'
import Waves from '../components/icons/Waves.astro'
import Tailwind from '../components/icons/Tailwind.astro'
import Alpine from '../components/icons/Alpine.astro'
import AstroIcon from '../components/icons/AstroIcon.astro'
import Nextjs from '../components/icons/Nextjs.astro'
import Typescript from '../components/icons/Typescript.astro'
import Swift from '../components/icons/Swift.astro'
import Statamic from '../components/icons/Statamic.astro'
import Laravel from '../components/icons/Laravel.astro'
import projects from '../data/projects.js'

const masonry = [
  'forehand.mp4',
  'masonry-1.jpg',
  'masonry-4.jpg',
  'masonry-2.jpg',
  'bench.mp4',
  'masonry-3.jpg',
  'masonry-7.jpg',
  'masonry-6.jpg',
  'serve.mp4',
  'masonry-8.jpg',
  'masonry-9.jpg',
  'masonry-10.jpg',
  'masonry-11.jpg',
  'masonry-5.jpg',
  'deadlift.mp4',
  'masonry-12.jpg',
]

const tools = [
  { name: 'Tailwind', Icon: Tailwind },
  { name: 'Alpine', Icon: Alpine },
  { name: 'Astro', Icon: AstroIcon },
  { name: 'Nextjs', Icon: Nextjs },
  { name: 'TypeScript', Icon: Typescript },
  { name: 'Swift', Icon: Swift },
  { name: 'Statamic', Icon: Statamic },
  { name: 'Laravel', Icon: Laravel },
]

const allPosts = await getCollection('blog')
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })

const recentProjects = projects.slice(0, 3)
---

<Layout
  title="Matt Waler builds websites, iOS apps, and plays a ton of tennis."
  description="Matt Waler is a web and iOS developer based in Ohio."
>
  <section
    class="
      py-32 lg:py-40 flex items-center justify-center
      text-white bg-linear-to-b from-blue-600 to-blue-950 to-90%
    "
  >
    <div class="container md:text-center">
      <div class="space-y-6 overlap max-w-4xl mx-auto">
        <!-- Reserve Space -->
        <div class="space-y-6">
          <p class="h1 opacity-0" role="presentation" aria-hidden="true">
            I develop websites, iOS applications, and play far too much Tennis.
          </p>
          <p class="h6 text-blue-200 text-balance">
            I also have a wife, a french bulldog, and an obsession with minimalism.
          </p>
        </div>
        <!-- Actual Content -->
        <div>
          <h1 class="h1">
            I develop websites, iOS applications, and
            <span
              x-data="{ typed: null }"
              x-intersect:leave="typed.destroy(); $el.innerText = 'play far too much tennis.'"
              x-init="
                () => typed = new Typed($el, {
                  strings: [
                    'listen to too much&nbsp;mgk.',
                    'redesign my website too&nbsp;often.',
                    'order too much&nbsp;Chipotle.'
                  ],
                  typeSpeed: 60,
                  startDelay: 1500,
                  backDelay: 1000,
                })
              "
            > play far too much Tennis.
            </span>
          </h1>
        </div>
      </div>
    </div>
  </section>

  <Waves class="text-blue-950 bg-white -mt-1 border-b border-white" />

  <section class="bg-white py-24 space-y-12 md:space-y-24">
    <div class="container text-balance text-center">
      <h2 class="h2">Who is Matt Waler?</h2>
      <h3 class="h5 mt-3 text-gray-600">
        They always say to show, don't tell.
      </h3>
    </div>
    <div
      class="grid grid-cols-[repeat(auto-fill,minmax(120px,1fr))] md:grid-cols-[repeat(auto-fill,minmax(280px,1fr))] container max-w-none gap-3 md:gap-5 grid-rows-[masonry]"
      x-init="new window.Masonry($el)"
    >
      {masonry.map(asset => (
        asset.endsWith('.mp4') ? (
          <video
            x-data="{ show: false }"
            x-intersect:enter.threshold.25="show = true"
            :class="show ? 'opacity-100' : 'opacity-0'"
            class="rounded-xl transition-opacity duration-500 pointer-events-none"
            autoplay muted playsinline loop src={`/masonry/${asset}`}
          ></video>
        ) : (
          <img
            x-data="{ show: false }"
            x-intersect:enter.threshold.25="show = true"
            :class="show ? 'opacity-100' : 'opacity-0'"
            src={`/masonry/${asset}`}
            loading="lazy"
            class="rounded-xl transition-opacity duration-500"
            alt=""
          />
        )
      ))}
    </div>
  </section>

  <Waves class="text-blue-950 bg-white scale-y-[-1.01] border-b border-white" />

  <section class="relative z-2 bg-white py-24 bg-linear-to-b from-blue-950 to-blue-600">
    <div class="container">
      <div class="md:text-center text-balance">
        <h2 class="h2 text-white">What does Matt Waler do?</h2>
        <h3 class="h5 text-blue-200 mt-4">Oh, you want to talk shop? Let's get right to it.</h3>
      </div>
      <div class="text-base mt-12 mb-16 text-balance md:text-center max-w-3xl mx-auto">
        <p class="text-lg text-blue-200">Whether it's a static website or a full-blown iOS application, I'm all about taking ideas and turning them into something tangible. I pride myself on keeping my code simple, practical, and easy to maintain, resorting to complexity only when absolutely necessary.</p>
      </div>
      <div class="grid grid-cols-2 min-[420px]:grid-cols-4 max-w-screen-sm mx-auto justify-center gap-8">
        {tools.map(({ name, Icon }) => (
          <div class="flex flex-col items-center gap-2.5">
            <Icon class="size-10 xs:size-16 text-white" />
            <p class="text-xs text-blue-100 font-mono text-balance">{name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Waves class="rotate-180 text-blue-600 bg-white -mt-1 border-b border-white scale-y-[-1.01]" />

  <section class="bg-white py-24">
    <div class="container">
      <div class="md:text-center text-balance">
        <h2 class="h2">What is Matt Waler thinking lately?</h2>
        <h3 class="h5 mt-3 text-gray-600">
          Thoughts, tutorials, and the occasional rant.
        </h3>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 mt-12">
        {recentPosts.map(post => (
          <article class="bg-white border rounded-xl shadow-xl overflow-clip">
            <div class="p-8 space-y-2">
              <time datetime={post.data.date.toISOString().split('T')[0]} class="block text-sm text-gray-600">
                {formatDate(post.data.date)}
              </time>
              <h4 class="h5 text-pretty">
                <a href={`/blog/${post.id.replace(/\.md$/, '')}/`} class="block font-bold hover:underline">
                  {post.data.title}
                </a>
              </h4>
              <p class="text-pretty lg:line-clamp-3">{post.data.description}</p>
            </div>
          </article>
        ))}
      </div>
      <div class="mt-12 md:text-center">
        <a href="/blog/" class="button">View All Posts</a>
      </div>
    </div>
  </section>

  <Waves class="text-gray-100 bg-white scale-y-[-1.01] border-b border-white" />

  <section class="py-24 bg-linear-to-b from-gray-100 to-white">
    <div class="container">
      <div class="md:text-center text-balance">
        <h2 class="h2">What is Matt Waler building?</h2>
        <h3 class="h5 mt-3 text-gray-600">
          A few things I've built recently.
        </h3>
      </div>
      <div class="grid grid-cols-1 xl:grid-cols-3 gap-12 mt-12">
        {recentProjects.map(project => (
          <article class="bg-white rounded-xl shadow-xl overflow-clip w-full sm:flex xl:block">
            <img
              width="1200"
              height="945"
              loading="lazy"
              class="aspect-1200/975 w-full h-auto bg-gray-200 sm:w-1/3 sm:aspect-auto sm:self-stretch sm:object-cover xl:w-full xl:aspect-1200/975"
              src={`/projects/${project.title.toLowerCase().replace(/\s+/g, '-')}.webp`}
              alt=""
            />
            <div class="p-8 space-y-2 border-t-2 sm:border-t-0 sm:border-l-2 sm:flex-1 xl:border-l-0 xl:border-t-2">
              <span class="block text-sm text-gray-600">
                {project.tools.join(', ')}
              </span>
              <h4 class="h5 text-pretty">
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block font-bold hover:underline transition-colors"
                >
                  {project.title}
                </a>
              </h4>
              <p class="text-pretty">{project.description}</p>
              {project.trendy && (
                <span class="block text-sm italic text-gray-600">
                  Completed while employed at <a href="https://trendyminds.com">TrendyMinds</a>.
                </span>
              )}
            </div>
          </article>
        ))}
      </div>
      <div class="mt-12 md:text-center">
        <a href="/projects/" class="button">View All Projects</a>
      </div>
    </div>
  </section>
</Layout>
