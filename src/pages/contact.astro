---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/Hero.astro'
import Waves from '../components/icons/Waves.astro'
---

<Layout
  title="Contact Matt Waler about your next website or application."
  description="Get in touch with Matt Waler to start your next web or mobile application."
>
  <Hero
    title="Let's get in touch."
    description="Thank you for taking the time to view my website. If you are interested in connecting, fill out the contact form below. I will get back to you as soon as possible."
  />

  <Waves />
  <section class="text-white bg-linear-to-t from-blue-600 to-blue-950 to-90%">
    <div class="container section max-w-3xl" x-data>
      <div x-cloak x-show="window.location.search.includes('contact=true')">
        <p class="h4 pt-16">Message sent! Thanks for reaching out!</p>
      </div>
      <form
        action="/contact/?contact=true"
        netlify
        class="mt-8 grid grid-cols-1 gap-8"
        method="POST"
        name="Contact Form"
      >
        <input type="hidden" name="form-name" value="Contact Form">
        <label class="grid grid-cols-1">
          <p>Name</p>
          <input required name="name" class="input" type="text">
        </label>
        <label class="grid grid-cols-1">
          <p>Email</p>
          <input required name="email" class="input" type="email">
        </label>
        <label class="grid grid-cols-1">
          <p>Message</p>
          <textarea required name="message" rows="5" class="input"></textarea>
        </label>
        <div>
          <button class="button rounded" type="submit">Submit</button>
        </div>
      </form>
    </div>
  </section>
  <Waves rotate foreground='#155dfc' />
</Layout>
