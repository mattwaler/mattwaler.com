---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/Hero.astro'
import Waves from '../components/icons/Waves.astro'
import projects from '../data/projects.js'
import ProjectCard from '../components/ProjectCard.astro'
---

<Layout
  title="Projects Matt Waler has built since 2016."
  description="Professional websites and iOS apps built for performance, scalability, and user experience — built to meet client and developer needs."
>
  <Hero
    title="See what I've built."
    description="I have built a lot of websites and mobile applications since I started back in 2016. Listed below is a non-exhaustive representation of what I have developed and deployed."
  />

  <Waves rotate foreground="white" background="#f3f4f6" />

  <section class="section bg-gray-100">
    <div class="container grid items-start grid-cols-1 xl:grid-cols-3 gap-12">
      {projects.map(project => (
        <ProjectCard project={project} />
      ))}
    </div>
  </section>

  <Waves foreground="white" background="#f3f4f6" />

</Layout>
