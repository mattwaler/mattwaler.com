---
import Layout from './Layout.astro'
import Waves from '../components/icons/Waves.astro'

interface Props {
  title: string
  description?: string
}

const { title, description } = Astro.props
---
<Layout title={title} description={description}>
  <section class="pt-48 pb-24 flex items-center justify-center">
    <div class="container md:text-center">
      <div class="space-y-6 overlap">
        <div class="space-y-6 w-full max-w-4xl mx-auto">
          <h1 class="h1 text-balance">
            {title}
          </h1>
          <p class="h6 opacity-75 text-balance">
            {description}
          </p>
        </div>
      </div>
    </div>
  </section>

  <Waves foreground='#f3f4f6' />

  <section class="bg-linear-to-t from-white to-gray-100 to-90%">
    <div class="container prose py-24 md:prose-lg md:max-w-3xl">
      <slot />
    </div>
  </section>
</Layout>
